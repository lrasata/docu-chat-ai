# Environment Configuration
environment = "staging"
app_id      = "docu-chat-ai"
region      = "us-east-1"

# Domain and DNS Configuration
api_file_upload_domain_name = "api-staging.your-domain.com"
alt_cloudfront_domain_name  = "staging.your-domain.com"
route53_zone_name          = "your-domain.com"

# SSL Certificate
backend_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/your-certificate-id"

# S3 Configuration
uploads_bucket_name         = "staging-docu-chat-ai-uploads"
enable_transfer_acceleration = false

# Lambda Configuration
lambda_memory_size_mb                         = 512
lambda_upload_presigned_url_expiration_time_s = 300

# S3 Ingestion Lambda (optional - for large deployments)
s3_ingestion_lambda_code_bucket = ""
s3_ingestion_lambda_code_key    = ""

# Notifications
notification_email                = "your-email@your-domain.com"
bucket_av_sns_findings_topic_name = "staging-bucket-av-findings"

# Bedrock Configuration
bedrock_model_id   = "anthropic.claude-3-sonnet-20240229-v1:0"
max_search_results = 5

# Note: Available Bedrock models:
# - anthropic.claude-3-sonnet-20240229-v1:0 (Recommended - balanced performance)
# - anthropic.claude-3-haiku-20240307-v1:0 (Fast and cost-effective)
# - anthropic.claude-3-opus-20240229-v1:0 (Most capable, higher cost)
# - meta.llama3-70b-instruct-v1:0 (Open source alternative)
